# === Google Gemini ===
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite
ZAI_API_KEY=

# === Meta / Instagram ===
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
# Token used for post and comment publishing
META_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_account_id
FACEBOOK_PAGE_ID=your_page_id
# Page token used for DMs. Obtain it via /me/accounts?fields=id,name,access_token
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# === Webhook ===
WEBHOOK_VERIFY_TOKEN=pbev_webhook_secret_2024
WEBHOOK_URL=https://bot.guiapbev.cloud/webhook

# === App Settings ===
HOST=0.0.0.0
PORT=8001
DATABASE_URL=sqlite:///pbev_instagram.db
LOG_LEVEL=INFO

# === Plausible Analytics ===
# Plausible CE API key (Settings > API Keys in the admin panel)
# Required to pull performance insights
PLAUSIBLE_API_KEY=
PLAUSIBLE_DOMAIN=guiapbev.cloud

# === Content Settings ===
DEFAULT_HASHTAGS=#veiculoeletrico,#carroeletrico,#mobilidadeeletrica,#EVBrasil,#GuiaPBEV
# SITE_URL is kept for legacy compatibility. Prefer separating:
PUBLIC_SITE_URL=https://guiapbev.cloud
IMAGE_BASE_URL=https://bot.guiapbev.cloud
IMAGE_FALLBACK_URL=
SITE_URL=https://guiapbev.cloud
POSTING_TIMEZONE=America/Sao_Paulo
ENABLE_AI_IMAGE_GENERATION=true
IMAGE_GENERATION_PROVIDER=gemini
IMAGE_GENERATION_MODEL=gemini-3.1-flash-image-preview
IMAGE_GENERATION_SIZE=1280x1280
COST_FX_BRL=5.70
