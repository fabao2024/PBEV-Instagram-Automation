# === Google Gemini ===
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# === Meta / Instagram ===
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_account_id
FACEBOOK_PAGE_ID=your_page_id

# === Webhook ===
WEBHOOK_VERIFY_TOKEN=pbev_webhook_secret_2024
WEBHOOK_URL=https://bot.guiapbev.cloud/webhook

# === App Settings ===
HOST=0.0.0.0
PORT=8001
DATABASE_URL=sqlite:///pbev_instagram.db
LOG_LEVEL=INFO

# === Plausible Analytics ===
# API key do Plausible CE (Settings > API Keys no painel admin)
# Necessário para puxar insights de performance
PLAUSIBLE_API_KEY=
PLAUSIBLE_DOMAIN=guiapbev.cloud

# === Content Settings ===
DEFAULT_HASHTAGS=#veiculoeletrico,#carroeletrico,#mobilidadeeletrica,#EVBrasil,#GuiaPBEV
# SITE_URL ficou como legado. Prefira separar:
PUBLIC_SITE_URL=https://guiapbev.cloud
IMAGE_BASE_URL=https://bot.guiapbev.cloud
SITE_URL=https://guiapbev.cloud
POSTING_TIMEZONE=America/Sao_Paulo
